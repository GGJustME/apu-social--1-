# NEXUS ENVIRONMENT VARIABLES (EXAMPLE)

# --- Frontend (Vite) ---
# Variables prefixed with VITE_ are exposed to the frontend.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- AI / Gemini (SERVER-SIDE ONLY) ---
# DO NOT prefix these with VITE_.
# These should ONLY be used in Supabase Edge Functions.
# Never expose these in vite.config.ts 'define' property.
GEMINI_API_KEY=your-google-ai-studio-key
