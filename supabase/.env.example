# SUPABASE CONFIG (Safe for Frontend)
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# LIVEKIT CONFIG
# ONLY the URL and API Key are safe for the frontend.
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_LIVEKIT_API_KEY=your-api-key

# !!! SECURITY WARNINGS !!!
# 1. LIVEKIT_API_SECRET must NEVER be in this file. 
#    It must be stored in Supabase Edge Function secrets or a secure backend.
# 2. GEMINI_API_KEY is currently used in the frontend for Phase 1 prototyping,
#    but MUST be moved to a secure backend/Edge Function before production.
#    Use VITE_GEMINI_API_KEY for local dev only.
VITE_GEMINI_API_KEY=your-gemini-key
